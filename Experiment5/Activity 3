# List of purchased items
purchases = ["apple", "banana", "apple", "orange", "banana", "apple"]

# Dictionary to store frequency
frequency = {}

# Count frequency
for item in purchases:
    if item in frequency:
        frequency[item] += 1
    else:
        frequency[item] = 1

print("Item Frequency:")
print(frequency)

